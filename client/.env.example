# ============================================================
# ReportCraft AI — Client Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ============================================================

# Vite exposes only VITE_ prefixed vars to the browser.

# --- Clerk (Frontend) ---
VITE_CLERK_PUBLISHABLE_KEY="pk_live_..."

# --- API URL ---
# In development, the Vite proxy forwards /api → http://localhost:8000
# Set this only when deploying frontend separately (e.g., Vercel).
# VITE_API_URL="https://your-backend.railway.app"

# --- PostHog Analytics (optional) ---
# VITE_POSTHOG_KEY="phc_..."
# VITE_POSTHOG_HOST="https://app.posthog.com"
